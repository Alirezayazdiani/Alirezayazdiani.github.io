<div class="news {% if include.timeline %}news-with-timeline{% endif %}">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    {% assign news = site.news | reverse %}

    {% if include.timeline %}
      {% assign news_limit = news_size %}
    {% elsif include.limit and page.announcements.limit %}
      {% assign news_limit = page.announcements.limit %}
    {% else %}
      {% assign news_limit = news_size %}
    {% endif %}

    {% assign expandable = false %}
    {% unless include.timeline %}
      {% if include.limit and news_size > news_limit %}
        {% assign expandable = true %}
      {% endif %}
    {% endunless %}

    {% if include.timeline %}
      {% assign timeline_months = include.initial_timeline_months | default: 6 %}
      <div
        class="news-timeline-widget mb-3"
        data-news-timeline-widget
        data-news-initial-months="{{ timeline_months }}"
      >
        <p class="news-timeline-hint text-muted small mb-2" id="news-timeline-help">
          By default the list shows about the last {{ timeline_months }} months—drag the shaded band to slide or resize the window, or click the gray
          rail to extend toward that date.
          <button type="button" class="news-timeline-reset btn btn-sm btn-link p-0 align-baseline ml-1">Show all dates</button>
        </p>
        <div class="news-timeline-status small font-weight-normal mb-1" aria-live="polite"></div>
        <div class="news-timeline-track" role="group" aria-labelledby="news-timeline-help">
          <div class="news-timeline-rail"></div>
          <div
            class="news-timeline-brush"
            tabindex="0"
            aria-label="Slide or resize the shaded region to filter news by date."
          >
            <button
              type="button"
              class="news-timeline-handle news-timeline-handle-l"
              tabindex="-1"
              aria-label="Drag to change earliest date"
            ></button>
            <div class="news-timeline-pan"></div>
            <button type="button" class="news-timeline-handle news-timeline-handle-r" tabindex="-1" aria-label="Drag to change latest date"></button>
          </div>
        </div>
      </div>
    {% endif %}

    <div
      class="table-responsive {% if expandable %}news-collapsed{% endif %}"
      id="news-list"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        <tbody>
          {% for item in news %}
            <tr
              class="news-row {% if expandable and forloop.index > news_limit %}news-extra{% endif %}"
              {% if include.timeline %}
                data-news-date="{{ item.date | date: '%Y-%m-%d' }}"
              {% endif %}
            >
              <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
              <td>
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          {% if include.timeline %}
            <tr class="news-timeline-empty-state" hidden>
              <td colspan="2" class="text-muted small py-2 fst-italic">No news in this window.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>

    {% if expandable %}
      {% assign hidden_count = news_size | minus: news_limit %}
      <button type="button" class="news-toggle" aria-expanded="false" aria-controls="news-list">
        <span class="news-toggle-more"> Show {{ hidden_count }} more <i class="fa-solid fa-chevron-down"></i> </span>
        <span class="news-toggle-less"> Show less <i class="fa-solid fa-chevron-up"></i> </span>
      </button>
      <script>
        (function () {
          var btn = document.currentScript.previousElementSibling;
          if (!btn || !btn.classList.contains('news-toggle')) return;
          var list = document.getElementById('news-list');
          if (!list) return;
          btn.addEventListener('click', function () {
            var collapsed = list.classList.toggle('news-collapsed');
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
          });
        })();
      </script>
    {% endif %}
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
