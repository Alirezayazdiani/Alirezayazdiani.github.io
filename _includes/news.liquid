<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    {% assign news = site.news | reverse %}

    {% if include.limit and page.announcements.limit %}
      {% assign news_limit = page.announcements.limit %}
    {% else %}
      {% assign news_limit = news_size %}
    {% endif %}

    {% assign expandable = false %}
    {% if include.limit and news_size > news_limit %}
      {% assign expandable = true %}
    {% endif %}

    <div
      class="table-responsive {% if expandable %}news-collapsed{% endif %}"
      id="news-list"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% for item in news %}
          <tr
            {% if expandable and forloop.index > news_limit %}
              class="news-extra"
            {% endif %}
          >
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>

    {% if expandable %}
      {% assign hidden_count = news_size | minus: news_limit %}
      <button type="button" class="news-toggle" aria-expanded="false" aria-controls="news-list">
        <span class="news-toggle-more"> Show {{ hidden_count }} more <i class="fa-solid fa-chevron-down"></i> </span>
        <span class="news-toggle-less"> Show less <i class="fa-solid fa-chevron-up"></i> </span>
      </button>
      <script>
        (function () {
          var btn = document.currentScript.previousElementSibling;
          if (!btn || !btn.classList.contains('news-toggle')) return;
          var list = document.getElementById('news-list');
          if (!list) return;
          btn.addEventListener('click', function () {
            var collapsed = list.classList.toggle('news-collapsed');
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
          });
        })();
      </script>
    {% endif %}
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
